rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ratings: public read + write (atomic increments prevent abuse)
    match /ratings/{toolSlug} {
      allow read: if true;
      allow write: if true;
    }

    // Feedback: public read + write (atomic increments)
    match /feedback/{toolSlug} {
      allow read: if true;
      allow write: if true;
    }

    // Newsletter: write-only (clients can't read other emails)
    match /newsletter_subscribers/{subId} {
      allow create: if true;
      allow read: if false;
      allow update, delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
